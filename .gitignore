/target
# Optional local IDA SDK checkout used via IDA_SDK_DIR (the build otherwise fetches).
/vendor
# Local-only machine/CI config: corpus location, R2 credentials. Never tracked.
.env
.env.*
compile_commands.json
**/*.i64
**/*.id0
**/*.id1
**/*.id2
**/*.nam
**/*.til
# cargo-mutants rotates its output dir to mutants.out.old on each run, so match both.
mutants.out*
# `just coverage` writes its lcov/html/json reports here; CI uploads them as artifacts instead.
/coverage
